# =============================================================================
# Deriv Bot — Environment Variables
# =============================================================================
# This file is the single source of truth for the env vars the app needs.
# Copy the relevant block below into a real env file, OR set the values in
# your hosting provider's dashboard (Vercel → Project Settings → Environment
# Variables, etc.). Values are read at BUILD TIME by Rsbuild via
# loadEnv({ prefixes: ['VITE_'] }) and exposed as `process.env.VITE_*` in the
# client bundle. Nothing is read from window.location at runtime.
#
# Rsbuild file precedence (highest to lowest):
#   .env.{mode}.local   →   .env.{mode}   →   .env.local   →   .env
# where {mode} is "development" (npm run start) or "production" (npm run build).
# Process env (Vercel / Replit secrets / shell exports) overrides everything.
# =============================================================================


# -----------------------------------------------------------------------------
# DEVELOPMENT  →  copy into `.env.development` for local dev outside Replit
# -----------------------------------------------------------------------------
# VITE_APP_ID=111670
# VITE_REDIRECT_URI=http://localhost:3000/
# VITE_OAUTH_URL=https://oauth.deriv.com/oauth2/authorize


# -----------------------------------------------------------------------------
# PRODUCTION  →  set these in Vercel → Settings → Environment Variables
#                (or copy into `.env.production` if building locally)
# -----------------------------------------------------------------------------
# VITE_APP_ID=111670
# VITE_REDIRECT_URI=https://derivfortunepro.vercel.app/
# VITE_OAUTH_URL=https://oauth.deriv.com/oauth2/authorize


# -----------------------------------------------------------------------------
# Variable reference
# -----------------------------------------------------------------------------
# VITE_APP_ID
#   Your Deriv app id. Register one at:
#   https://app.deriv.com/account/api-token  →  "Register application"
#
# VITE_REDIRECT_URI
#   Full OAuth redirect URL Deriv will send users back to after login.
#   MUST be registered against the app id above (Deriv app settings).
#   Always points to the site root (/). Tokens are captured there by runEarlyAuth().
#
# VITE_OAUTH_URL
#   Deriv OAuth authorize endpoint. In normal use the value is always
#   https://oauth.deriv.com/oauth2/authorize.
