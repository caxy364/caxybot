# Deriv OAuth configuration.
# Copy this file to `.env` and override per environment.
# These values are read at build time by Rsbuild via loadEnv({ prefixes: ['VITE_'] }).

# Your Deriv app id (https://app.deriv.com/account/api-token > "Register application").
VITE_APP_ID=111670

# Full OAuth redirect URL that Deriv will send the user back to after login.
# It MUST match the redirect URL configured for the app id above.
# Examples:
#   Local development:   http://localhost:5000/auth/callback
#   Replit preview:      https://<your-repl>.replit.dev/auth/callback
#   Replit deployment:   https://<your-app>.replit.app/auth/callback
#   Production (Vercel): https://your-domain.com/auth/callback
VITE_REDIRECT_URI=https://your-domain.example.com/auth/callback

# Deriv OAuth authorize endpoint.
VITE_OAUTH_URL=https://oauth.deriv.com/oauth2/authorize
